{
  "name": "@pronto/payer-experience-builder",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Generates a bespoke per-biller payer PWA skin, builds it, validates it with a scripted Playwright gate, and publishes the built bundle to Blob Storage.",
  "bin": {
    "payer-build": "./src/cli.ts"
  },
  "scripts": {
    "build:one": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test src/*.test.ts",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@azure/identity": "^4.5.0",
    "@azure/storage-blob": "^12.26.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "~5.7.2"
  }
}
