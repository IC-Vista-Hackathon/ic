# Pronto Biller Studio -- local development environment template
#
# Copy this file to `.env` (already git-ignored) and fill in any values you need to override.
# Everything below is a non-secret endpoint URL or a non-secret client ID from the hackathon
# sandbox infra (subscription `poc-vista-hackathon`, resource group `rg-ic-hack`, region
# eastus2, deployed from infra/bicep/main.bicep). Nothing in this file is a password, key,
# token, or connection string -- it is safe to commit `.env.example` itself.
#
# Used by: Pronto.BillerExperience.Api, Pronto.BillerExperience.Worker (see services/README.md).
# ASP.NET Core configuration binds double-underscore env vars to nested config sections
# automatically (e.g. `Cosmos__Endpoint` -> `Cosmos:Endpoint`), so these names match what
# appsettings.Development.json would use if you prefer that instead.

# --- Authentication: workload identity vs. local dev -------------------------------------
#
# In-cluster (AKS), the API and Worker run as the `ic-workload` / `biller-publisher`
# Kubernetes service accounts, which are federated to the `uami-ic-hack-workload` managed
# identity below (see infra/bicep/modules/aks.bicep). Azure.Identity's
# `DefaultAzureCredential` picks this up automatically via the AKS workload identity webhook
# (AZURE_CLIENT_ID / AZURE_TENANT_ID / AZURE_FEDERATED_TOKEN_FILE are injected into the pod --
# you do not set them yourself in the cluster).
#
# Running locally (outside AKS), there is no federated token available, so workload identity
# does NOT work. `DefaultAzureCredential` will instead fall back to your own credentials --
# run `az login` first, or configure a dedicated service principal with client secret for
# local dev, and grant it the same Cosmos "Data Contributor" / Cognitive Services "User" roles
# that the workload identity has (see infra/bicep/modules/cosmos.bicep and aiFoundry.bicep).
#
# AZURE_CLIENT_ID below is NOT a secret -- it identifies which managed identity the workload
# uses in-cluster. It is only useful to reference locally; it does not let you authenticate
# as that identity from your workstation.
AZURE_CLIENT_ID=12fe469e-b4ee-4293-a535-e4ff1ae45c24

# --- Cosmos DB (Azure Cosmos DB for NoSQL) ------------------------------------------------
# Used by: Pronto.BillerExperience.Api, Pronto.BillerExperience.Worker
# Database `ic` contains 8 containers per design/entities.md's "Cosmos conventions" section:
# billers, configs, deployments, payer_accounts, invoices, payments, purchases, notifications.
# No key/connection-string is used -- auth is via Azure AD (workload identity or `az login`),
# so only the endpoint is needed here.
COSMOS__ENDPOINT=https://cosmos-ic-hack-jk4zmntatjem4.documents.azure.com:443/
COSMOS__DATABASENAME=ic

# --- Azure AI Foundry (agent model inference) ---------------------------------------------
# Used by: Pronto.Agentic.Orchestration (via Pronto.BillerExperience.Api)
# Project `ic` under the AI Foundry account. Two model deployments are available; pick the
# smaller one for cheap/dev iterations.
AIFOUNDRY__ENDPOINT=https://aif-ic-hack-jk4zmntatjem4.cognitiveservices.azure.com/
AIFOUNDRY__PROJECTNAME=ic
AIFOUNDRY__MODELDEPLOYMENT=gpt-5.4
AIFOUNDRY__MODELDEPLOYMENT_MINI=gpt-5.4-mini

# Persisted-agent project endpoint used by the runtime Research Coordinator. Worker agents must
# carry `ic.approved=true` and `ic.capabilities=biller_research` metadata. Set the coordinator ID
# after publishing the `agents/research-coordinator` definition; leave it empty to use deterministic
# citation-preserving consolidation.
BillerExperience__Research__FoundryProjectEndpoint=https://aif-ic-hack-jk4zmntatjem4.services.ai.azure.com/api/projects/ic
BillerExperience__Research__CoordinatorAgentId=
BillerExperience__AgentProvisioning__Enabled=false
BillerExperience__AgentProvisioning__DefinitionsPath=agents
BillerExperience__AgentProvisioning__PrimaryModel=gpt-5.4
BillerExperience__AgentProvisioning__MiniModel=gpt-5.4-mini
BillerExperience__AgentProvisioning__McpConnectionId=ic-shared-context-mcp

# Shared biller/run context for agents. HTTP is accepted for the hackathon demo; use HTTPS and
# a managed secret source outside the demo. Both secrets must contain at least 32 characters.
BillerExperience__Mcp__Enabled=false
BillerExperience__Mcp__PublicEndpoint=http://pronto.eastus2.cloudapp.azure.com/api/mcp
BillerExperience__Mcp__ApiKey=
BillerExperience__Mcp__CapabilitySigningKey=

# --- Container registry / AKS (only relevant if building images or deploying) -------------
# Used by: Pronto.BillerExperience.Worker's publish path, and CI/deploy tooling, not typically
# needed for day-to-day API/Worker local development.
ACR_LOGIN_SERVER=acrichackjk4zmntatjem4.azurecr.io
AKS_CLUSTER_NAME=aks-ic-hack
